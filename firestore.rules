rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function getStaffRole() {
      return get(/databases/$(database)/documents/staff/$(request.auth.uid)).data.role;
    }

    function isAdmin() {
      return request.auth != null && getStaffRole() == 'Admin';
    }

    function isStaffOrAdmin() {
      return request.auth != null && getStaffRole() in ['Admin', 'Supervisor', 'Staff'];
    }

    function isGuardian() {
      return request.auth != null && exists(/databases/$(database)/documents/guardians/$(request.auth.uid));
    }

    match /zones/{zoneId} {
      allow read: if request.auth != null;
      allow write: if isStaffOrAdmin();
    }

    match /users/{userId} {
      allow read, write: if isStaffOrAdmin();
      allow read: if isGuardian() && resource.data.guardianUid == request.auth.uid;
    }

    match /staff/{staffId} {
      allow read: if isStaffOrAdmin();
      allow write: if isAdmin();
    }

    match /sessions/{sessionId} {
      allow read, write: if isStaffOrAdmin();
    }

    match /bracelets/{braceletId} {
      allow read, write: if isStaffOrAdmin();
    }

    match /attendanceLogs/{logId} {
      allow read: if isStaffOrAdmin();
      allow create: if isStaffOrAdmin();
      allow update: if isStaffOrAdmin();
      allow delete: if isAdmin();
    }

    match /auditLogs/{logId} {
      allow read: if isAdmin();
      allow create: if isStaffOrAdmin();
    }

    match /guardians/{guardianUid} {
      allow read, write: if request.auth.uid == guardianUid;
      allow read: if isStaffOrAdmin();
    }

    match /systemConfig/{docId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }
  }
}
