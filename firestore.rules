rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    // A guardian is identified by having a doc in guardians/{uid}
    function isGuardian() {
      return isSignedIn() && exists(/databases/$(database)/documents/guardians/$(request.auth.uid));
    }

    // Staff and admin are any authenticated users who are NOT guardians
    function isStaffOrAdmin() {
      return isSignedIn() && !isGuardian();
    }

    match /zones/{zoneId} {
      allow read: if isSignedIn();
      allow write: if isStaffOrAdmin();
    }

    match /users/{userId} {
      allow read, write: if isStaffOrAdmin();
      allow read: if isGuardian() && resource.data.guardianUid == request.auth.uid;
      // Guardians can create children records linked to their own UID during registration
      allow create: if isSignedIn() && request.resource.data.guardianUid == request.auth.uid;
    }

    match /staff/{staffId} {
      allow read, write: if isStaffOrAdmin();
    }

    match /sessions/{sessionId} {
      allow read, write: if isStaffOrAdmin();
    }

    match /bracelets/{braceletId} {
      allow read, write: if isStaffOrAdmin();
    }

    match /attendanceLogs/{logId} {
      allow read, write: if isStaffOrAdmin();
      allow read: if isGuardian() &&
        resource.data.userId in get(/databases/$(database)/documents/guardians/$(request.auth.uid)).data.childrenIds;
    }

    match /auditLogs/{logId} {
      allow read, write: if isStaffOrAdmin();
    }

    match /guardians/{guardianUid} {
      allow read, write: if request.auth.uid == guardianUid;
      allow read: if isStaffOrAdmin();
    }

    match /systemConfig/{docId} {
      allow read: if isSignedIn();
      allow write: if isStaffOrAdmin();
    }

    match /notifications/{notifId} {
      allow read: if isStaffOrAdmin() || (isGuardian() && resource.data.guardianId == request.auth.uid);
      allow create: if isStaffOrAdmin();
    }

    // Minimal public index used to validate guardian emails before sending password resets.
    // Contains only { exists: true } — no sensitive data.
    match /guardianEmails/{emailKey} {
      allow read: if true;
      allow create: if isSignedIn() &&
        request.resource.data.keys().hasOnly(['exists']) &&
        request.resource.data.exists == true;
    }
  }
}
